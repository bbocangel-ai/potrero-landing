---
import Layout from '@/layouts/Layout.astro'

const BASE        = import.meta.env.BASE_URL
const logoSrc     = `${BASE}brand/isotipo-color.png`.replace(/\/+/g, '/')
const hubUrl      = `${BASE}herramientas/`.replace(/\/+/g, '/')
const whatsappUrl = import.meta.env.PUBLIC_WHATSAPP_URL
---

<Layout
  title="Cálculo de Suplementación — Herramientas Potrero"
  description="Calculá la cantidad exacta de suplemento para tu rebaño. Consumo diario en kg, sacos por día y costo total. Bs/saco."
>
<div class="min-h-screen bg-[#F5F5F5] font-sans">

  {/* ── HEADER ── */}
  <header class="bg-[#1E4230] text-white px-5 py-4 flex items-center justify-between gap-4 shadow-md sticky top-0 z-40">
    <a href={hubUrl} class="flex items-center gap-2 text-earth-300 hover:text-white transition-colors text-sm">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
      Herramientas
    </a>
    <a href={hubUrl} class="flex items-center gap-2">
      <img src={logoSrc} alt="Potrero" class="w-7 h-7 object-contain" />
      <span class="font-display font-medium text-[1rem] tracking-tight">Potrero</span>
    </a>
    <a href={whatsappUrl} target="_blank" rel="noopener noreferrer"
      class="text-xs font-semibold bg-[#25D366] hover:bg-[#1faf54] text-white px-3 py-1.5 rounded-lg transition-colors hidden sm:block">
      WhatsApp
    </a>
  </header>

  {/* ── TITLE BAR ── */}
  <div class="bg-white border-b border-gray-200 px-5 py-4">
    <div class="max-w-3xl mx-auto flex items-center gap-4">
      <div class="w-11 h-11 rounded-xl bg-red-100 flex items-center justify-center shrink-0">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#DC2626" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 3H5a2 2 0 0 0-2 2v4m6-6h10a2 2 0 0 1 2 2v4M9 3v18m0 0h10a2 2 0 0 0 2-2V9M9 21H5a2 2 0 0 1-2-2V9m0 0h18"/></svg>
      </div>
      <div>
        <h1 class="font-bold text-gray-900 text-lg leading-tight">Cálculo de Suplementación</h1>
        <p class="text-gray-500 text-xs mt-0.5">Consumo diario · Sacos por día · Costo total en Bs</p>
      </div>
    </div>
  </div>

  {/* ── MAIN ── */}
  <main class="max-w-3xl mx-auto px-4 py-6 space-y-5">

    {/* ── FORMULARIO ── */}
    <div class="bg-white rounded-2xl border border-gray-200 p-5 md:p-6">
      <h2 class="font-bold text-gray-800 text-sm mb-5 flex items-center gap-2">
        <span class="w-5 h-5 rounded-full bg-red-500 text-white text-[10px] font-bold flex items-center justify-center">1</span>
        Datos del rebaño y suplemento
      </h2>

      <div class="grid sm:grid-cols-2 gap-4">

        <div class="field-wrap">
          <label for="f-cabezas">Cantidad de animales</label>
          <p class="field-hint">Total de cabezas a suplementar</p>
          <div class="input-suf">
            <input id="f-cabezas" type="number" min="1" value="200" />
            <span>cab.</span>
          </div>
        </div>

        <div class="field-wrap">
          <label for="f-peso">Peso promedio del rebaño</label>
          <p class="field-hint">Peso medio obtenido en la pesada</p>
          <div class="input-suf">
            <input id="f-peso" type="number" min="1" value="350" />
            <span>kg PV</span>
          </div>
        </div>

        <div class="field-wrap">
          <label for="f-tipo">Tipo de suplementación</label>
          <p class="field-hint">El % de consumo se actualiza automático</p>
          <select id="f-tipo"
            class="w-full border border-gray-200 rounded-lg px-3 py-2.5 text-sm text-gray-900 bg-gray-50 focus:outline-none focus:border-red-400 transition">
            <option value="0.1">Proteinado — mantenimiento (0,1 % PV)</option>
            <option value="0.2">Proteinado — recría leve (0,2 % PV)</option>
            <option value="0.3">Proteico-energético — recría (0,3 % PV)</option>
            <option value="0.4">Proteico-energético — recría intensiva (0,4 % PV)</option>
            <option value="0.5">Proteico-energético — engorde (0,5 % PV)</option>
            <option value="1.0">Concentrado engorde — semifinal (1,0 % PV)</option>
            <option value="1.5">Concentrado engorde — final (1,5 % PV)</option>
            <option value="2.0">Concentrado engorde — intensivo (2,0 % PV)</option>
          </select>
        </div>

        <div class="field-wrap">
          <label for="f-pct">Porcentaje de consumo</label>
          <p class="field-hint">Automático según tipo · podés ajustar</p>
          <div class="input-suf">
            <input id="f-pct" type="number" min="0.01" max="5" step="0.01" value="0.1" />
            <span>% PV</span>
          </div>
        </div>

        <div class="field-wrap">
          <label for="f-saco">Peso del saco</label>
          <p class="field-hint">Peso estándar del saco de suplemento</p>
          <div class="input-suf">
            <input id="f-saco" type="number" min="1" value="40" />
            <span>kg/saco</span>
          </div>
        </div>

        <div class="field-wrap">
          <label for="f-precio-saco">Precio por saco <span class="text-gray-400 font-normal text-[10px]">(opcional)</span></label>
          <p class="field-hint">Para calcular el costo total</p>
          <div class="input-pre">
            <span>Bs</span>
            <input id="f-precio-saco" type="number" min="0" step="10" value="0" placeholder="0" />
          </div>
        </div>

      </div>
    </div>

    {/* ── KPI CARDS ── */}
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">

      <div class="bg-white rounded-2xl border border-gray-200 p-4 sm:col-span-2">
        <p class="text-[10px] text-gray-400 uppercase tracking-wider font-semibold mb-1">Consumo diario total</p>
        <p class="text-3xl font-bold text-gray-900 leading-none"><span id="r-consumo-kg">0,0</span> <span class="text-lg font-normal text-gray-500">kg/día</span></p>
        <p class="text-xs text-gray-400 mt-1.5" id="r-consumo-formula">— × — × —</p>
      </div>

      <div class="bg-blue-50 border border-blue-200 rounded-2xl p-4">
        <p class="text-[10px] text-blue-500 uppercase tracking-wider font-semibold mb-1">Sacos/día (exacto)</p>
        <p class="text-3xl font-bold text-blue-700 leading-none" id="r-sacos-exacto">0,00</p>
        <p class="text-xs text-blue-400 mt-1.5" id="r-sacos-formula">—</p>
      </div>

      <div class="bg-amber-50 border border-amber-200 rounded-2xl p-4">
        <p class="text-[10px] text-amber-600 uppercase tracking-wider font-semibold mb-1">Sacos/día (práctico)</p>
        <p class="text-3xl font-bold text-amber-700 leading-none" id="r-sacos-redond">0</p>
        <p class="text-xs text-amber-400 mt-1.5">Cantidad práctica a suministrar</p>
      </div>

    </div>

    {/* ── COSTOS (visible si precio > 0) ── */}
    <div id="panel-costos" class="hidden bg-[#1E4230] text-white rounded-2xl p-5">
      <p class="text-earth-400 text-[10px] font-bold uppercase tracking-widest mb-4">Costos del suplemento</p>
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 text-center">
        <div>
          <p class="text-earth-500 text-[10px] uppercase tracking-wide mb-1">Costo diario</p>
          <p class="text-white font-bold text-lg">Bs <span id="r-costo-dia">0</span></p>
        </div>
        <div>
          <p class="text-earth-500 text-[10px] uppercase tracking-wide mb-1">Costo semanal</p>
          <p class="text-white font-bold text-lg">Bs <span id="r-costo-sem">0</span></p>
        </div>
        <div>
          <p class="text-earth-500 text-[10px] uppercase tracking-wide mb-1">Costo mensual</p>
          <p class="text-earth-300 font-bold text-lg">Bs <span id="r-costo-mes">0</span></p>
        </div>
        <div>
          <p class="text-earth-500 text-[10px] uppercase tracking-wide mb-1">Costo / cab / mes</p>
          <p class="text-earth-300 font-bold text-lg">Bs <span id="r-costo-cab">0</span></p>
        </div>
      </div>
    </div>

    {/* ── TABLA COMPARATIVA ── */}
    <div class="bg-white rounded-2xl border border-gray-200 overflow-hidden">
      <div class="px-5 py-4 border-b border-gray-100">
        <h2 class="font-bold text-gray-800 text-sm">Tabla comparativa de suplementación</h2>
        <p class="text-xs text-gray-400 mt-0.5">Para tu rebaño actual — la fila seleccionada está resaltada</p>
      </div>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="bg-gray-50 text-gray-500 text-xs uppercase tracking-wide">
              <th class="text-left px-5 py-3 font-semibold">Tipo</th>
              <th class="text-right px-4 py-3 font-semibold">% PV</th>
              <th class="text-right px-4 py-3 font-semibold">kg/día</th>
              <th class="text-right px-4 py-3 font-semibold">Sacos/día</th>
              <th class="text-right px-5 py-3 font-semibold" id="col-costo-header" style="display:none">Bs/día</th>
            </tr>
          </thead>
          <tbody id="tabla-body" class="divide-y divide-gray-50">
          </tbody>
        </table>
      </div>
    </div>

    {/* ── ACCIONES ── */}
    <div class="flex flex-col sm:flex-row gap-3">
      <button onclick="window.print()"
        class="flex-1 flex items-center justify-center gap-2 bg-red-600 hover:bg-red-700 text-white font-semibold text-sm px-5 py-3 rounded-xl transition-colors">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><rect x="6" y="14" width="12" height="8"/></svg>
        Imprimir / Exportar PDF
      </button>
      <a href={whatsappUrl} target="_blank" rel="noopener noreferrer"
        class="flex-1 flex items-center justify-center gap-2 bg-[#25D366] hover:bg-[#1faf54] text-white font-semibold text-sm px-5 py-3 rounded-xl transition-colors">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
        Consultar con Potrero
      </a>
    </div>

    <p class="text-center text-xs text-gray-400 pb-2">Potrero © {new Date().getFullYear()} · Herramienta gratuita · Bolivia 🇧🇴</p>
  </main>
</div>
</Layout>

<style>
  .field-wrap { @apply flex flex-col gap-1; }
  .field-wrap label { @apply text-xs font-semibold text-gray-700; }
  .field-hint { @apply text-[11px] text-red-400 -mt-0.5; }

  .input-suf {
    @apply flex items-center border border-gray-200 rounded-lg overflow-hidden bg-gray-50 focus-within:border-red-400 focus-within:bg-white transition;
  }
  .input-suf input { @apply flex-1 bg-transparent px-3 py-2.5 text-sm text-gray-900 focus:outline-none border-none min-w-0; }
  .input-suf span  { @apply bg-gray-100 border-l border-gray-200 px-3 py-2.5 text-xs text-gray-500 font-medium shrink-0; }

  .input-pre {
    @apply flex items-center border border-gray-200 rounded-lg overflow-hidden bg-gray-50 focus-within:border-red-400 focus-within:bg-white transition;
  }
  .input-pre span  { @apply bg-gray-100 border-r border-gray-200 px-3 py-2.5 text-xs text-gray-500 font-medium shrink-0; }
  .input-pre input { @apply flex-1 bg-transparent px-3 py-2.5 text-sm text-gray-900 focus:outline-none border-none min-w-0; }

  @media print {
    header { display: none !important; }
    .bg-\[#F5F5F5\] { background: white !important; }
  }
</style>

<script>
  // ── Tipos de suplementación ──────────────────────────
  const TIPOS = [
    { label: 'Proteinado — mantenimiento',     pct: 0.1  },
    { label: 'Proteinado — recría leve',        pct: 0.2  },
    { label: 'Proteico-energético — recría',    pct: 0.3  },
    { label: 'Proteico-energético — recría int.',pct: 0.4 },
    { label: 'Proteico-energético — engorde',   pct: 0.5  },
    { label: 'Concentrado engorde — semifinal', pct: 1.0  },
    { label: 'Concentrado engorde — final',     pct: 1.5  },
    { label: 'Concentrado engorde — intensivo', pct: 2.0  },
  ]

  const $ = (id: string) => document.getElementById(id)!
  const inp = (id: string) => parseFloat(($(`f-${id}`) as HTMLInputElement).value) || 0
  const fmt = (n: number, d = 1) => n.toLocaleString('es-BO', { minimumFractionDigits: d, maximumFractionDigits: d })

  // Sync tipo → pct
  ;($('f-tipo') as HTMLSelectElement).addEventListener('change', (e) => {
    const pct = parseFloat((e.target as HTMLSelectElement).value)
    ;($('f-pct') as HTMLInputElement).value = String(pct)
    calc()
  })

  function calc() {
    const cabezas    = inp('cabezas')
    const peso       = inp('peso')
    const pct        = inp('pct')          // % PV
    const pesoSaco   = inp('saco')
    const precioSaco = inp('precio-saco')
    const pctSel     = parseFloat(($('f-tipo') as HTMLSelectElement).value)

    // Cálculo principal
    const consumoDia  = cabezas * peso * (pct / 100)       // kg/día
    const sacosExacto = pesoSaco > 0 ? consumoDia / pesoSaco : 0
    const sacosRedond = Math.ceil(sacosExacto)

    // KPI cards
    $('r-consumo-kg').textContent    = fmt(consumoDia, 1)
    $('r-consumo-formula').textContent = `${fmt(peso,0)} kg × ${fmt(pct,2)}% × ${fmt(cabezas,0)} cab.`
    $('r-sacos-exacto').textContent  = fmt(sacosExacto, 2)
    $('r-sacos-formula').textContent = `${fmt(consumoDia,1)} kg ÷ ${fmt(pesoSaco,0)} kg/saco`
    $('r-sacos-redond').textContent  = String(sacosRedond)

    // Costos
    const panelCostos = $('panel-costos')
    const colHeader   = $('col-costo-header')
    if (precioSaco > 0) {
      const costoDia = sacosExacto * precioSaco
      $('r-costo-dia').textContent = fmt(costoDia, 0)
      $('r-costo-sem').textContent = fmt(costoDia * 7, 0)
      $('r-costo-mes').textContent = fmt(costoDia * 30, 0)
      $('r-costo-cab').textContent = cabezas > 0 ? fmt((costoDia * 30) / cabezas, 1) : '0'
      panelCostos.classList.remove('hidden')
      colHeader.style.display = ''
    } else {
      panelCostos.classList.add('hidden')
      colHeader.style.display = 'none'
    }

    // Tabla comparativa
    const tbody = $('tabla-body')
    tbody.innerHTML = TIPOS.map(t => {
      const kg    = cabezas * peso * (t.pct / 100)
      const sacos = pesoSaco > 0 ? kg / pesoSaco : 0
      const costo = precioSaco > 0 ? sacos * precioSaco : null
      const sel   = Math.abs(t.pct - pct) < 0.001  // selected row

      const rowClass = sel
        ? 'bg-green-50 border-l-4 border-l-green-500'
        : 'hover:bg-gray-50 border-l-4 border-l-transparent'

      const badge = sel ? '<span class="ml-2 text-[9px] bg-green-100 text-green-700 font-bold px-1.5 py-0.5 rounded-full uppercase tracking-wide">Seleccionado</span>' : ''

      return `
        <tr class="${rowClass} transition-colors">
          <td class="px-5 py-3 text-sm ${sel ? 'font-semibold text-green-700' : 'text-gray-700'}">${t.label}${badge}</td>
          <td class="px-4 py-3 text-right text-sm ${sel ? 'font-bold text-green-700' : 'text-gray-500'}">${t.pct}%</td>
          <td class="px-4 py-3 text-right text-sm font-semibold ${sel ? 'text-green-700' : 'text-blue-600'}">${fmt(kg, 1)}</td>
          <td class="px-4 py-3 text-right text-sm font-bold ${sel ? 'text-green-700' : 'text-gray-900'}">${Math.ceil(sacos)}</td>
          ${precioSaco > 0 ? `<td class="px-5 py-3 text-right text-sm font-semibold text-gray-700">${fmt(sacos * precioSaco, 0)}</td>` : ''}
        </tr>
      `
    }).join('')
  }

  document.querySelectorAll('input[type="number"]').forEach(el => el.addEventListener('input', calc))
  calc()
</script>
