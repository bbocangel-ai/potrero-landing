---
import Layout from '@/layouts/Layout.astro'

const whatsappUrl = 'https://wa.me/59177423154?text=Hola%20Potrero,%20me%20interesa%20saber%20m%C3%A1s'
const landingUrl = `${import.meta.env.BASE_URL}`.replace(/\/+$/, '/')
const isotipoSrc = `${import.meta.env.BASE_URL}brand/isotipo-color.png`.replace(/\/+/g, '/')

const links = [
  {
    label: 'Conocer Potrero',
    sub: 'Mirá qué hacemos y sumate a la lista',
    href: landingUrl,
    icon: 'web',
    primary: false,
  },
  {
    label: 'WhatsApp directo',
    sub: 'Hablemos por WhatsApp Business',
    href: whatsappUrl,
    icon: 'whatsapp',
    primary: true,
    external: true,
  },
]
---

<Layout
  title="Potrero — Contactanos"
  description="Hablá con Potrero por WhatsApp o conocé más del proyecto."
>
  <main class="min-h-screen bg-earth-100 flex flex-col items-center justify-center px-5 py-10 relative overflow-hidden">

    {/* Decoración: TopoLines sutiles atrás */}
    <svg
      aria-hidden="true"
      class="absolute inset-0 w-full h-full opacity-[0.06] pointer-events-none"
      viewBox="0 0 700 900"
      preserveAspectRatio="xMidYMid slice"
    >
      {Array.from({ length: 12 }).map((_, i) => (
        <path
          d={`M-80,${60 + i * 78} C120,${30 + i * 78} 260,${100 + i * 78} 370,${65 + i * 78} S600,${25 + i * 78} 780,${80 + i * 78}`}
          fill="none"
          stroke="#1E4230"
          stroke-width="1"
        />
      ))}
    </svg>

    <div class="relative z-10 w-full max-w-md flex flex-col items-center">

      {/* Logo + nombre */}
      <img
        src={isotipoSrc}
        alt="Potrero"
        class="w-24 h-24 object-contain mb-4"
      />
      <h1 class="font-display font-medium text-[2.25rem] text-potrero-900 leading-none tracking-tight">
        Potrero
      </h1>
      <p class="font-display italic text-earth-700 text-base mt-1">
        Tu campo, tus números.
      </p>

      <span class="inline-block w-12 h-0.5 bg-earth-400 rounded-sm my-6" aria-hidden="true"></span>

      {/* Tagline */}
      <p class="text-center text-potrero-800 text-base leading-relaxed mb-8 max-w-xs">
        Gestión ganadera profesional para estancias de Santa Cruz.
        <span class="block mt-1.5 font-semibold text-potrero-900">De productores, para productores.</span>
      </p>

      {/* Lista de links */}
      <div class="w-full space-y-3">
        {links.map((link) => (
          <a
            href={link.href}
            target={link.external ? '_blank' : undefined}
            rel={link.external ? 'noopener noreferrer' : undefined}
            class={`flex items-center gap-4 px-5 py-4 rounded-2xl shadow-warm-sm transition-all duration-200 hover:-translate-y-0.5 hover:shadow-warm-lg group ${
              link.primary
                ? 'bg-[#25D366] text-white hover:bg-[#1faf54]'
                : 'bg-earth-50 border border-earth-200 text-potrero-900 hover:border-earth-400'
            }`}
          >
            <div class={`w-11 h-11 rounded-xl flex items-center justify-center shrink-0 ${
              link.primary ? 'bg-white/20' : 'bg-potrero-100'
            }`}>
              {link.icon === 'whatsapp' && (
                <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" class={link.primary ? 'text-white' : 'text-potrero-700'} aria-hidden="true">
                  <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
                </svg>
              )}
              {link.icon === 'web' && (
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-potrero-700" aria-hidden="true">
                  <circle cx="12" cy="12" r="10"/>
                  <path d="M2 12h20"/>
                  <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
                </svg>
              )}
            </div>
            <div class="flex-1 min-w-0">
              <p class={`font-semibold leading-tight ${link.primary ? 'text-white' : 'text-potrero-900'}`}>
                {link.label}
              </p>
              <p class={`text-xs mt-0.5 ${link.primary ? 'text-white/85' : 'text-earth-700'}`}>
                {link.sub}
              </p>
            </div>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class={`transition-transform group-hover:translate-x-1 ${link.primary ? 'text-white/80' : 'text-earth-600'}`} aria-hidden="true">
              <path d="M5 12h14"/>
              <path d="m12 5 7 7-7 7"/>
            </svg>
          </a>
        ))}
      </div>

      {/* Footer */}
      <p class="mt-10 text-center text-xs text-earth-700/60">
        Potrero &copy; {new Date().getFullYear()} &middot; Hecho en Bolivia 🇧🇴
      </p>
    </div>
  </main>
</Layout>
