---
const whatsappUrl = import.meta.env.PUBLIC_WHATSAPP_URL
---

<section class="relative overflow-hidden">
  {/* Fondo con imagen del campo + overlay gradient */}
  <div class="absolute inset-0">
    <img
      src="/fotos/01-hero-ganado.jpg"
      alt=""
      class="w-full h-full object-cover"
      aria-hidden="true"
      onerror="this.style.display='none'"
    />
    <div class="absolute inset-0 bg-gradient-to-br from-potrero-900/85 via-potrero-800/75 to-potrero-700/80"></div>
  </div>

  <div class="relative container-prose py-20 md:py-28 lg:py-36">
    <div class="max-w-3xl">
      {/* Eyebrow */}
      <p class="text-earth-300 text-xs md:text-sm font-bold uppercase tracking-[0.2em] mb-6 animate-fade-in-up">
        De productores, para productores
      </p>

      {/* Título principal */}
      <h1 class="font-display font-medium text-white leading-[1.05] tracking-tight mb-6 animate-fade-in-up"
          style="font-size: clamp(2.75rem, 6vw, 4.75rem); animation-delay: 0.1s;">
        Tu campo,<br />
        tus <em class="italic text-earth-400 font-normal">números.</em>
      </h1>

      {/* Subtítulo */}
      <p class="text-earth-200/85 text-lg md:text-xl leading-relaxed max-w-2xl mb-10 animate-fade-in-up"
         style="animation-delay: 0.25s;">
        Gestión ganadera profesional para estancias de Santa Cruz.
        Sabé exactamente cuánto te cuesta cada kilo producido.
        <span class="text-earth-300 font-semibold">Dejá el Excel.</span>
      </p>

      {/* CTAs */}
      <div class="flex flex-col sm:flex-row gap-3 animate-fade-in-up" style="animation-delay: 0.4s;">
        <a
          href={whatsappUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="btn-whatsapp"
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
          </svg>
          Contactanos por WhatsApp
        </a>
        <a href="#encuesta" class="btn-secondary !bg-transparent !text-earth-100 !border-earth-200 hover:!bg-earth-200 hover:!text-potrero-900">
          Sumate a la lista
          <svg width="16" height="16" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
            <path d="M10.75 8.75a.75.75 0 01.75-.75h3.5a.75.75 0 01.75.75v3.5a.75.75 0 01-1.5 0V10.56l-6.22 6.22a.75.75 0 01-1.06-1.06l6.22-6.22H11.5a.75.75 0 01-.75-.75z"/>
            <path d="M2 4.75C2 3.784 2.784 3 3.75 3h6.5a.75.75 0 010 1.5h-6.5a.25.25 0 00-.25.25v10.5c0 .138.112.25.25.25h10.5a.25.25 0 00.25-.25v-6.5a.75.75 0 011.5 0v6.5A1.75 1.75 0 0114.25 17H3.75A1.75 1.75 0 012 15.25V4.75z"/>
          </svg>
        </a>
      </div>

      {/* Prueba social micro */}
      <p class="mt-12 text-sm text-earth-300/70 animate-fade-in-up" style="animation-delay: 0.6s;">
        Basado en estándares de gestión ganadera profesional de Bolivia.
      </p>
    </div>
  </div>
</section>
