---
const filas = [
  { label: 'Inventario ganadero',       excel: 'Manual, con errores',     potrero: '13 categorías, automático' },
  { label: 'Carga animal UA/ha',        excel: 'Lo calculás a mano',      potrero: 'Automático por potrero' },
  { label: 'Cascada económica',         excel: 'Solo el contador la arma', potrero: 'En tiempo real' },
  { label: 'Comparar gestiones',        excel: 'Imposible en la práctica', potrero: 'Dos clicks' },
  { label: 'Pluviometría histórica',    excel: 'Cuaderno aparte',         potrero: 'Integrada, con alertas' },
  { label: 'Costo por kilo producido',  excel: 'Fin de año, con suerte',  potrero: 'Siempre actualizado' },
  { label: 'Disponible en el celular',  excel: 'No',                      potrero: 'Siempre, donde estés' },
]
---

<section class="py-16 md:py-24 bg-earth-100">
  <div class="container-prose">
    <div class="max-w-2xl mb-14">
      <p class="eyebrow mb-3">La diferencia</p>
      <span class="title-accent mb-6"></span>
      <h2 class="font-display font-medium text-potrero-900 leading-[1.1] tracking-tight text-[2.25rem] md:text-[2.75rem] mt-4">
        Excel vs <em class="italic text-earth-600">Potrero.</em>
      </h2>
    </div>

    <div class="overflow-x-auto rounded-2xl border border-earth-200 bg-earth-50 shadow-warm-sm">
      <table class="w-full text-left">
        <thead>
          <tr class="border-b border-earth-200">
            <th class="py-4 px-5 md:px-7 eyebrow font-semibold">Lo que necesitás hacer</th>
            <th class="py-4 px-5 md:px-7 eyebrow font-semibold text-earth-600">Excel / papel</th>
            <th class="py-4 px-5 md:px-7 eyebrow font-semibold text-potrero-700">Potrero</th>
          </tr>
        </thead>
        <tbody>
          {filas.map((r, i) => (
            <tr class={i % 2 === 0 ? 'bg-transparent' : 'bg-earth-100/50'}>
              <td class="py-4 px-5 md:px-7 font-semibold text-potrero-900">{r.label}</td>
              <td class="py-4 px-5 md:px-7 text-potrero-800/70">
                <span class="inline-flex items-center gap-2">
                  <svg width="16" height="16" viewBox="0 0 20 20" fill="currentColor" class="text-red-600/80">
                    <path d="M6.28 5.22a.75.75 0 00-1.06 1.06L8.94 10l-3.72 3.72a.75.75 0 101.06 1.06L10 11.06l3.72 3.72a.75.75 0 101.06-1.06L11.06 10l3.72-3.72a.75.75 0 00-1.06-1.06L10 8.94 6.28 5.22z"/>
                  </svg>
                  {r.excel}
                </span>
              </td>
              <td class="py-4 px-5 md:px-7 text-potrero-900 font-medium">
                <span class="inline-flex items-center gap-2">
                  <svg width="16" height="16" viewBox="0 0 20 20" fill="currentColor" class="text-potrero-600">
                    <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd"/>
                  </svg>
                  {r.potrero}
                </span>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>
</section>
