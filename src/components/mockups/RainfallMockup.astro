---
// Lluvia mensual en mm — ejemplo estancia chiquitana, gestión típica
const rainfall = [
  { m: 'Jul', mm: 8   },
  { m: 'Ago', mm: 12  },
  { m: 'Sep', mm: 35  },
  { m: 'Oct', mm: 72  },
  { m: 'Nov', mm: 145 },
  { m: 'Dic', mm: 210 },
  { m: 'Ene', mm: 245 },
  { m: 'Feb', mm: 198 },
  { m: 'Mar', mm: 162 },
  { m: 'Abr', mm: 88  },
  { m: 'May', mm: 34  },
  { m: 'Jun', mm: 14  },
]
const total = rainfall.reduce((acc, x) => acc + x.mm, 0)
const max = Math.max(...rainfall.map((x) => x.mm))

// Opacidad según mm (heatmap)
const opacityFor = (mm: number) => {
  const ratio = mm / max
  return 0.2 + ratio * 0.8
}
---

<div class="relative w-full h-full min-h-[260px] bg-gradient-to-br from-earth-50 to-earth-100 p-5 flex items-center justify-center">
  <div class="w-full max-w-[420px] bg-white rounded-xl shadow-warm-sm border border-earth-200 overflow-hidden">
    <div class="px-4 py-3 border-b border-earth-200 bg-earth-50/60">
      <div class="flex items-center justify-between">
        <span class="text-[0.7rem] font-bold uppercase tracking-wider text-potrero-700">
          Pluviometría · 2024/25
        </span>
        <span class="text-[0.7rem] text-earth-600 font-medium">Est. La Flauta</span>
      </div>
      <div class="flex items-baseline gap-2 mt-1.5">
        <span class="font-display text-[1.5rem] font-medium text-potrero-900 tabular-nums">
          {total} mm
        </span>
        <span class="text-[0.7rem] text-earth-600">acumulados 12 meses</span>
      </div>
    </div>

    {/* Heatmap de 12 meses */}
    <div class="p-4">
      <div class="grid grid-cols-6 gap-1.5">
        {rainfall.map((r) => (
          <div class="flex flex-col items-center">
            <div
              class="w-full aspect-square rounded-md flex items-center justify-center"
              style={`background: rgba(30, 66, 48, ${opacityFor(r.mm)});`}
            >
              <span
                class="font-semibold text-[0.68rem] tabular-nums"
                style={`color: ${r.mm > 80 ? '#FAF6EE' : '#1E4230'};`}
              >
                {r.mm}
              </span>
            </div>
            <span class="text-[0.6rem] text-earth-700 font-medium mt-1">{r.m}</span>
          </div>
        ))}
      </div>

      {/* Footer con alerta */}
      <div class="mt-3 pt-3 border-t border-earth-100 flex items-center gap-2">
        <span class="inline-flex items-center gap-1.5 px-2 py-0.5 rounded-md bg-potrero-50 border border-potrero-200 text-[0.65rem] font-semibold text-potrero-700">
          <span class="w-1.5 h-1.5 rounded-full bg-potrero-500"></span>
          Gestión lluviosa
        </span>
        <span class="text-[0.65rem] text-earth-700">+12% vs promedio histórico</span>
      </div>
    </div>
  </div>
</div>
